{
  "name": "wct",
  "version": "2.0.0",
  "description": "Git worktree workflow automation CLI",
  "module": "src/index.ts",
  "type": "module",
  "license": "MIT",
  "bin": {
    "wct": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun --bun node_modules/.bin/vitest run",
    "lint": "bunx biome check",
    "typecheck": "tsc --noEmit",
    "format": "bunx biome check --write",
    "build": "bun build src/index.ts --compile --outfile dist/wct",
    "build:all": "bun run scripts/build-all.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@effect/vitest": "4.0.0-beta.98",
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.17",
    "bun-types": "1.3.14",
    "react-devtools-core": "^7.0.1",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "typescript": "7.0.2"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.98",
    "effect": "4.0.0-beta.98",
    "ink": "7.1.1",
    "react": "^19.2.7"
  }
}
