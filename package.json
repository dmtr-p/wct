{
  "name": "wct",
  "version": "2.0.0",
  "description": "Git worktree workflow automation CLI",
  "module": "src/index.ts",
  "type": "module",
  "license": "MIT",
  "bin": {
    "wct": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun --bun node_modules/.bin/vitest run",
    "lint": "bunx biome check",
    "format": "bunx biome check --write",
    "build": "bun build src/index.ts --compile --outfile dist/wct",
    "build:all": "bun run scripts/build-all.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@effect/vitest": "4.0.0-beta.92",
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.17",
    "bun-types": "1.3.14",
    "react-devtools-core": "^7.0.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.84",
    "effect": "4.0.0-beta.92",
    "ink": "7.0.5",
    "react": "^19.2.7"
  }
}
